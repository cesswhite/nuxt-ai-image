# Public site URL (SEO, og:url, canonical). Example: https://ai-images.example.com
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI (GPT Image + Enhance / Surprise text helpers) — server only
# OPENAI_API_KEY=
# Optional chat model for Enhance prompt & Surprise me (default: gpt-4o-mini)
# OPENAI_PROMPT_MODEL=gpt-4o-mini

# Google Gemini / Imagen — server only (any one of these names works with runtime config)
# GEMINI_API_KEY=
# NUXT_GEMINI_API_KEY=
# GOOGLE_API_KEY=
