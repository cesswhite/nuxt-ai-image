# Public site URL (SEO, og:url, canonical). Example: https://ai-images.example.com
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# When true, POST /api/generate-image returns an inline SVG placeholder — no OpenAI/Google calls.
# Set to false when you implement real SDK calls in server/api/generate-image.post.ts
NUXT_PUBLIC_IMAGE_GEN_DEMO=true

# OpenAI (GPT Image) — server only
# OPENAI_API_KEY=

# Google Gemini / Imagen — server only (any one of these names works with runtime config)
# GEMINI_API_KEY=
# NUXT_GEMINI_API_KEY=
# GOOGLE_API_KEY=
